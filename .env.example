APP_NAME=Mzuni UNITRAS
APP_ENV=local
APP_KEY=base64:YOUR_EXISTING_KEY_OR_GENERATE_NEW
APP_DEBUG=true
APP_URL=https://sauna-define-hazing.ngrok-free.dev   # ← Use your current ngrok URL

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database – keep as is (works)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mzuni_unitras
DB_USERNAME=root
DB_PASSWORD=

# Session – use FILE to avoid missing sessions table (or run session migration)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcast (for WebSocket tracking)
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (optional)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="unitras@mzuni.ac.mw"
MAIL_FROM_NAME="Mzuni UNITRAS"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Vite (for frontend assets)
VITE_APP_NAME="${APP_NAME}"

